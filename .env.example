# SecToolbox 环境变量示例
# 复制为 .env.local（开发）或部署时设置为服务器环境变量

# ========== 登录鉴权 (B1 方案) ==========
# 多用户格式：user1:pass1,user2:pass2
AUTH_USERS=admin:changeme_strong_password,guest:guest_pw

# HMAC 签名密钥，至少 16 字符，建议 64 字符
# 生成：openssl rand -hex 32
AUTH_SECRET=REPLACE_WITH_openssl_rand_hex_32_OUTPUT

# session 有效期（小时），默认 168 = 7 天
AUTH_TTL_HOURS=168

# ========== 其他 ==========
# 如有 IP 情报 API key 等，追加在此
